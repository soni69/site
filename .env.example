# ─── Payload CMS ──────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-key-min-32-chars
REVALIDATION_SECRET=your-revalidation-secret

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# For Docker Compose — service name "postgres" is the host
DATABASE_URL=postgresql://kiro:your-password@postgres:5432/kiro

# PostgreSQL container credentials (used by docker-compose.yml)
POSTGRES_PASSWORD=your-password
POSTGRES_USER=kiro
POSTGRES_DB=kiro

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kiro-service.ru

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Maps (optional) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
