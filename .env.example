# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default — leave empty or set a file path):
# DATABASE_URL=file:./database.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ─── Payload CMS ─────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Must be a long random string (32+ chars).
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── On-demand revalidation ──────────────────────────────────────────────────
# Secret token for the /api/revalidate webhook endpoint.
REVALIDATION_SECRET=change-me-to-another-random-secret

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Maps ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
